            if RootPart and getgenv().OldPos then
                repeat
                    RootPart.CFrame = getgenv().OldPos
                    Character:SetPrimaryPartCFrame(getgenv().OldPos)
                    if Humanoid then Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
                    for _, part in next, Character:GetChildren() do
                        if part:IsA("BasePart") then
                            part.Velocity = Vector3.zero
                            part.RotVelocity = Vector3.zero
                        end
                    end
                    task.wait()
                until (RootPart.Position - getgenv().OldPos.p).Magnitude < 5
                if getgenv().FPDH then workspace.FallenPartsDestroyHeight = getgenv().FPDH end
            end
        end
