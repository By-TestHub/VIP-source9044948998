local vehicleFlyActive = false
local vehicleSpeed = 80 
local vBV, vBG

game:GetService("RunService").RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")

    if vehicleFlyActive and hum and hum.SeatPart then
        local seat = hum.SeatPart
        
        if not vBV or vBV.Parent ~= seat then
            if vBV then vBV:Destroy() end
            vBV = Instance.new("BodyVelocity")
            vBV.MaxForce = Vector3.new(1e9, 1e9, 1e9)
            vBV.Parent = seat
        end
        
        if not vBG or vBG.Parent ~= seat then
            if vBG then vBG:Destroy() end
            vBG = Instance.new("BodyGyro")
            vBG.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
            vBG.P = 10000
            vBG.D = 100
            vBG.Parent = seat
        end
        
        local cam = workspace.CurrentCamera
        local moveDir = hum.MoveDirection
        
        if moveDir.Magnitude > 0 then
            local camLook = cam.CFrame.LookVector
            local flatLook = Vector3.new(camLook.X, 0, camLook.Z)
            if flatLook.Magnitude > 0 then flatLook = flatLook.Unit else flatLook = Vector3.new(0, 0, -1) end
            
            local camRight = cam.CFrame.RightVector
            local flatRight = Vector3.new(camRight.X, 0, camRight.Z)
            if flatRight.Magnitude > 0 then flatRight = flatRight.Unit else flatRight = Vector3.new(1, 0, 0) end
            
            local forwardIntent = moveDir:Dot(flatLook)
            local rightIntent = moveDir:Dot(flatRight)
            
            local flyDir = (cam.CFrame.LookVector * forwardIntent) + (cam.CFrame.RightVector * rightIntent)
            vBV.Velocity = flyDir * vehicleSpeed
        else
            vBV.Velocity = Vector3.zero
        end
        vBG.CFrame = cam.CFrame
    else
        if vBV then vBV:Destroy(); vBV = nil end
        if vBG then vBG:Destroy(); vBG = nil end
    end
end)

